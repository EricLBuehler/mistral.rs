apiVersion: v1
kind: Secret
metadata:
  name: mistralrs-secret
  namespace: {{namespace}}
  labels:
    app: mistralrs
type: Opaque
stringData:
  # KV-Cache Compression (TurboQuant)
  # Requires image built with --features kvcache-compression
  MISTRALRS_KV_CACHE_BITS: "{{kv_bits}}"
  MISTRALRS_KV_CACHE_THRESHOLD: "{{kv_threshold}}"

  # HuggingFace token for gated models (Llama, Gemma, etc.)
  # Replace with your actual token or use a sealed-secret provider
  HF_TOKEN: "REPLACE_WITH_HF_TOKEN"
