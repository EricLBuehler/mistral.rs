#!/usr/bin/env bash
# mistral.rs Quickstart
# Generated by mistralrs-config-wizard
set -euo pipefail

BINARY="${MISTRALRS_BINARY:-mistralrs}"
CONFIG="${MISTRALRS_CONFIG:-config.toml}"

# ─── Feature check ─────────────────────────────────────────────────────────────
if [[ "{{kv_bits}}" != "" ]]; then
  if ! "$BINARY" --version 2>/dev/null | grep -q "kvcache-compression"; then
    echo "WARNING: kv_compression_bits = {{kv_bits}} is set but the binary may not"
    echo "         have been built with --features kvcache-compression."
    echo "         Rebuild: cargo build --release --features kvcache-compression"
    echo ""
  fi
fi

# ─── Option A: TOML config (recommended) ───────────────────────────────────────
echo "Starting mistral.rs from config..."
"$BINARY" from-config --file "$CONFIG"

# ─── Option B: Direct CLI flags (equivalent, uncomment to use) ─────────────────
# "$BINARY" {{command}} \
#   -m {{model_id}} \
#   --isq {{isq_level}} \
#   --port {{port}} \
#   --max-seqs {{max_seqs}} \
#   --kv-cache-bits {{kv_bits}} \
#   --kv-cache-threshold {{kv_threshold}} \
#   --paged-attn-memory-fraction {{memory_fraction}}

# ─── Option C: Environment variable approach ────────────────────────────────────
# export MISTRALRS_KV_CACHE_BITS={{kv_bits}}
# export MISTRALRS_KV_CACHE_THRESHOLD={{kv_threshold}}
# "$BINARY" {{command}} -m {{model_id}} --isq {{isq_level}} --port {{port}}
