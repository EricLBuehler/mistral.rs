apiVersion: v1
kind: ConfigMap
metadata:
  name: mistralrs-config
  namespace: {{namespace}}
  labels:
    app: mistralrs
data:
  config.toml: |
    command = "{{command}}"

    [server]
    host = "0.0.0.0"
    port = {{port}}
    ui = {{ui}}

    [runtime]
    max_seqs = {{max_seqs}}

    [paged_attn]
    mode = "auto"
    memory_fraction = {{memory_fraction}}

    [[models]]
    kind = "{{kind}}"
    model_id = "{{model_id}}"
    dtype = "{{dtype}}"

    [models.quantization]
    in_situ_quant = "{{isq_level}}"

    [models.device]
    max_seq_len = {{max_seq_len}}

    # kv_compression_bits and kv_compression_threshold are passed via Secret env vars
    # (MISTRALRS_KV_CACHE_BITS / MISTRALRS_KV_CACHE_THRESHOLD) rather than config.toml
    # to allow per-environment override without changing the ConfigMap.
