# mistral.rs Configuration
# Generated by mistralrs-config-wizard
# Run with: mistralrs from-config --file config.toml

command = "{{command}}"  # "serve" or "run"

# ─── Global Options ────────────────────────────────────────────────────────────
# [global]
# seed = 42                    # Random seed for reproducibility
# log = "requests.log"         # Log all requests/responses
# token_source = "cache"       # HF auth: cache | none | literal:<t> | env:<v> | path:<f>

# ─── Server (serve only) ───────────────────────────────────────────────────────
[server]
host = "{{host}}"
port = {{port}}
ui = {{ui}}
# mcp_port = 8080              # Enable MCP server on this port
# mcp_config = "mcp.json"      # MCP client configuration

# ─── Runtime ───────────────────────────────────────────────────────────────────
[runtime]
max_seqs = {{max_seqs}}
# no_kv_cache = false          # Disable KV cache entirely (use only if extremely constrained)
# prefix_cache_n = 16          # Prefix caches to hold (0 = disable)
# chat_template = "template.jinja"
# enable_search = false
# search_embedding_model = "google/embeddinggemma-300m"

# ─── PagedAttention ────────────────────────────────────────────────────────────
[paged_attn]
mode = "{{paged_attn_mode}}"    # auto | on | off (auto = CUDA on, Metal off)
memory_fraction = {{memory_fraction}}  # GPU fraction for KV blocks (0.0–1.0)
# context_len = 131072         # Alternative: fixed context length (exclusive with memory_fraction)
# block_size = 32              # Tokens per KV block

# ─── Model ─────────────────────────────────────────────────────────────────────
[[models]]
kind = "{{kind}}"               # auto | text | vision | diffusion | speech | embedding
model_id = "{{model_id}}"
dtype = "{{dtype}}"             # auto | f16 | bf16 | f32

# ─── Quantization ──────────────────────────────────────────────────────────────
[models.quantization]
in_situ_quant = "{{isq_level}}" # q4k | q8 | q4_0 | q6k — omit to load as-is
# from_uqff = "model.uqff"     # Load pre-quantized UQFF file instead

# ─── Device Mapping ────────────────────────────────────────────────────────────
[models.device]
max_seq_len = {{max_seq_len}}
max_batch_size = {{max_batch_size}}
# cpu = false                  # Force CPU-only (must match across all [[models]])
# device_layers = ["0:40", "1:40"]  # Multi-GPU layer split
# topology = "topology.yaml"   # Topology YAML for fine-grained device mapping
# hf_cache = "/data/hf-cache"  # Custom HuggingFace cache directory

# ─── KV-Cache Compression (TurboQuant) ────────────────────────────────────────
# Requires: cargo build --features kvcache-compression
# Env var equivalents: MISTRALRS_KV_CACHE_BITS, MISTRALRS_KV_CACHE_THRESHOLD
#
# bits decision guide:
#   >30% VRAM free   → omit (disabled)
#   15-30% free      → bits=4, threshold=4096
#   5-15% free       → bits=3, threshold=4096  (RECOMMENDED)
#   <5% free         → bits=3, threshold=128
#   critical <2%     → bits=2, threshold=0
{{#if kv_bits}}
[models.cache]
kv_compression_bits = {{kv_bits}}          # 2=max compression, 4=best quality, 3=recommended
kv_compression_threshold = {{kv_threshold}}  # tokens before compression starts
{{/if}}

# ─── Vision Options (vision models only) ───────────────────────────────────────
# [models.vision]
# max_edge = 1120              # Max image edge length
# max_num_images = 4           # Max images per request

# ─── LoRA / X-LoRA (optional) ──────────────────────────────────────────────────
# [models.adapter]
# lora = "adapter1;adapter2"   # LoRA adapter IDs, semicolon-separated
# xlora = "xlora-model-id"     # X-LoRA (mutually exclusive with lora)
# xlora_order = "order.json"   # Required with xlora
