# mistral.rs Environment Variables
# Generated by mistralrs-config-wizard
# Usage: source .env  (or set in your container/systemd config)

# ─── KV-Cache Compression (TurboQuant) ────────────────────────────────────────
# These are the env-var equivalents of [models.cache] in config.toml.
# CLI flags (--kv-cache-bits / --kv-cache-threshold) take precedence over these.
# Requires: cargo build --features kvcache-compression
MISTRALRS_KV_CACHE_BITS={{kv_bits}}
MISTRALRS_KV_CACHE_THRESHOLD={{kv_threshold}}

# ─── HuggingFace Authentication ────────────────────────────────────────────────
# Required for gated models (Llama, Gemma, etc.)
# HF_TOKEN=hf_YOUR_TOKEN_HERE
# Alternative: run `huggingface-cli login` once to cache credentials

# ─── Model Cache ───────────────────────────────────────────────────────────────
# Override the default ~/.cache/huggingface directory
# HF_HUB_CACHE=/data/models/cache

# ─── Runtime Behavior ──────────────────────────────────────────────────────────
# MISTRALRS_DEBUG=0            # Set to 1 for verbose debug output
# MISTRALRS_NO_MMAP=0          # Set to 1 to disable memory-mapped file loading
# MISTRALRS_NO_MLA=0           # Set to 1 to disable MLA optimization (DeepSeek/GLM)
# MISTRALRS_ISQ_SINGLETHREAD=0 # Set to 1 to force single-threaded ISQ

# ─── Server ────────────────────────────────────────────────────────────────────
# MCP_CONFIG_PATH=mcp.json     # Fallback MCP config path
# KEEP_ALIVE_INTERVAL=10000    # SSE keep-alive in ms

# ─── GPU (CUDA only) ───────────────────────────────────────────────────────────
# MISTRALRS_IGPU_MEMORY_FRACTION=0.75  # For Jetson / Grace Blackwell integrated GPUs
