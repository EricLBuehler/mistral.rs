{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Workflow Trigger",
  "description": "Schema for workflow triggers that fire at evolution lifecycle events",
  "type": "object",
  "required": ["triggers"],
  "properties": {
    "triggers": {
      "type": "array",
      "items": { "$ref": "#/definitions/trigger" }
    }
  },
  "definitions": {
    "trigger": {
      "type": "object",
      "required": ["id", "event", "action"],
      "properties": {
        "id": {
          "type": "string",
          "description": "Unique identifier for this trigger"
        },
        "event": {
          "type": "string",
          "enum": [
            "on_phase_start",
            "on_phase_complete",
            "on_iteration_complete",
            "on_cycle_complete",
            "on_regression",
            "on_approval_required"
          ],
          "description": "Lifecycle event that fires this trigger"
        },
        "condition": {
          "type": ["string", "null"],
          "description": "Optional condition expression (e.g., \"phase == 'execute' && domain == 'software'\")"
        },
        "description": {
          "type": "string",
          "description": "Human-readable description of what this trigger does"
        },
        "action": { "$ref": "#/definitions/action" }
      }
    },
    "action": {
      "type": "object",
      "required": ["type", "target"],
      "properties": {
        "type": {
          "type": "string",
          "enum": ["command", "webhook", "mcp_tool", "workflow_file"],
          "description": "Type of action to execute"
        },
        "target": {
          "type": "string",
          "description": "What to execute: command string, URL, MCP tool name, or file path"
        },
        "inputs": {
          "type": "object",
          "description": "Data passed to the action. Supports ${variable} substitution.",
          "additionalProperties": true
        },
        "timeout": {
          "type": "integer",
          "minimum": 1,
          "default": 30,
          "description": "Maximum execution time in seconds"
        }
      }
    }
  }
}
