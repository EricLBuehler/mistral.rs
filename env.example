# Mistral.rs Environment Variables
# Copy this file to .env and customize as needed

# ============================================================================
# Authentication & API Tokens
# ============================================================================

# Hugging Face API token for downloading models
# Used for accessing gated models and increasing rate limits
# Get your token from: https://huggingface.co/settings/tokens
# HF_TOKEN=hf_xxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Alternative for testing environments (used in CI)
# TESTS_HF_TOKEN=hf_xxxxxxxxxxxxxxxxxxxxxxxxxxxxx


# ============================================================================
# Scheduler Configuration (parking-lot-scheduler feature)
# ============================================================================

# Path to YAML scheduler configuration file
# When set, this file is loaded to configure the parking-lot scheduler
# Priority: --scheduler-config CLI > MISTRALRS_SCHEDULER_CONFIG > ~/.mistralrs-server/scheduler.yaml
# MISTRALRS_SCHEDULER_CONFIG=/path/to/scheduler.yaml


# ============================================================================
# MCP (Model Context Protocol) Configuration
# ============================================================================

# Path to MCP client configuration file (JSON)
# Used to configure external tool connections and services
# See: docs/MCP/configuration.md
# MCP_CONFIG_PATH=/path/to/mcp-config.json


# ============================================================================
# Multi-Node Distributed Inference
# ============================================================================

# Global world size for multi-node setups (total number of processes)
# When set, enables multi-node distributed inference
# MISTRALRS_MN_GLOBAL_WORLD_SIZE=4

# Head node configuration (for the coordinator node)
# Number of worker nodes to expect
# MISTRALRS_MN_HEAD_NUM_WORKERS=3
# Port for the head node server
# MISTRALRS_MN_HEAD_PORT=8080

# Worker node configuration (for non-head nodes)
# Address of the head node server (format: IP:PORT)
# MISTRALRS_MN_WORKER_SERVER_ADDR=192.168.1.100:8080
# Unique worker ID (0-indexed, must be unique per worker)
# MISTRALRS_MN_WORKER_ID=0


# ============================================================================
# CUDA Build Configuration
# ============================================================================

# Additional flags to pass to nvcc during CUDA compilation
# Useful for platform-specific compilation requirements
# Example: CUDA_NVCC_FLAGS=-fPIE for some Linux distributions
# CUDA_NVCC_FLAGS=

# CUDA compute capability (e.g., 7.5, 8.0, 8.6, 9.0)
# Auto-detected via nvidia-smi if not set
# Specify this to force a specific compute capability
# CUDA_COMPUTE_CAP=8.6

# Path to CUDA nvcc compiler (for custom CUDA installations)
# NVCC_CCBIN=/usr/bin/gcc-10


# ============================================================================
# Metal Kernel Compilation (macOS)
# ============================================================================

# Skip Metal kernel precompilation during build
# Useful for CI or when Metal is not needed
# Set to 0, false, or leave unset to enable precompilation (default)
# Set to 1 or true to skip precompilation
# MISTRALRS_METAL_PRECOMPILE=0


# ============================================================================
# Debugging & Development
# ============================================================================

# Enable debug mode for additional logging and diagnostics
# When set to 1:
#   - Outputs tensor information for GGUF/GGML models to mistralrs_gguf_tensors.txt
#   - Enables more verbose logging throughout the application
# MISTRALRS_DEBUG=1

# Disable memory-mapped file loading
# When set to 1, models will be loaded entirely into RAM instead of using mmap
# Useful for debugging memory issues or on filesystems that don't support mmap
# MISTRALRS_NO_MMAP=1


# ============================================================================
# Internal Flags (DO NOT SET MANUALLY)
# ============================================================================

# Internal daemon flag (set automatically by distributed inference)
# __MISTRALRS_DAEMON_INTERNAL=1


# ============================================================================
# Usage Examples
# ============================================================================

# Example 1: Development with debug mode and local scheduler config
# MISTRALRS_DEBUG=1
# MISTRALRS_SCHEDULER_CONFIG=./dev-scheduler.yaml
# HF_TOKEN=hf_xxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Example 2: Production multi-node setup (head node)
# HF_TOKEN=hf_xxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# MISTRALRS_MN_GLOBAL_WORLD_SIZE=4
# MISTRALRS_MN_HEAD_NUM_WORKERS=3
# MISTRALRS_MN_HEAD_PORT=8080
# MISTRALRS_SCHEDULER_CONFIG=/etc/mistralrs/production.yaml

# Example 3: Production multi-node setup (worker node)
# HF_TOKEN=hf_xxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# MISTRALRS_MN_GLOBAL_WORLD_SIZE=4
# MISTRALRS_MN_WORKER_SERVER_ADDR=192.168.1.100:8080
# MISTRALRS_MN_WORKER_ID=0

# Example 4: Custom CUDA build with specific compute capability
# CUDA_COMPUTE_CAP=8.6
# CUDA_NVCC_FLAGS=-fPIE
# NVCC_CCBIN=/usr/bin/gcc-11

# Example 5: CI/Testing environment
# TESTS_HF_TOKEN=hf_xxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# MISTRALRS_METAL_PRECOMPILE=0
# MISTRALRS_DEBUG=1


# ============================================================================
# Notes
# ============================================================================

# 1. Token Security:
#    - NEVER commit .env files with real tokens to version control
#    - Use .gitignore to exclude .env files
#    - Rotate tokens if accidentally exposed

# 2. Priority & Overrides:
#    - CLI arguments always take precedence over environment variables
#    - Environment variables take precedence over config files
#    - Example: --token-source env:HF_TOKEN uses this file's HF_TOKEN

# 3. Multi-Node Setup:
#    - Head node requires: GLOBAL_WORLD_SIZE, HEAD_NUM_WORKERS, HEAD_PORT
#    - Worker nodes require: GLOBAL_WORLD_SIZE, WORKER_SERVER_ADDR, WORKER_ID
#    - All nodes should have the same GLOBAL_WORLD_SIZE value

# 4. Scheduler Configuration:
#    - YAML file format, see examples/scheduler-config.yaml
#    - CLI flags can override individual YAML settings
#    - Default location: ~/.mistralrs-server/scheduler.yaml

# 5. Build-Time vs Runtime:
#    - CUDA_*, NVCC_*, MISTRALRS_METAL_PRECOMPILE: Build-time only
#    - All others: Runtime (can be changed without rebuilding)

# 6. Documentation Links:
#    - Main README: README.md
#    - Scheduler Config: docs/SCHEDULER_CONFIG.md
#    - MCP Configuration: docs/MCP/configuration.md
#    - Distributed Setup: docs/DISTRIBUTED/
#    - Build Guide: AGENTS.md
